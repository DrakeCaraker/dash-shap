#!/usr/bin/env bash
# Pre-commit hook: run ruff and mypy before allowing a commit.
# Install: git config core.hooksPath .githooks

set -e

echo "Running pre-commit checks..."

# Block commits that include private research strategy files
PRIVATE_PATTERNS=(
    "ROADMAP.md"
    "docs/RESEARCH_DIRECTIONS.md"
    "docs/EXTENSIONS.md"
    "paper/REVIEW_v"
    "PRIVATE_RESEARCH_CONTEXT.md"
)
BLOCKED=()
for pattern in "${PRIVATE_PATTERNS[@]}"; do
    matches=$(git diff --cached --name-only | grep -F "$pattern" || true)
    if [ -n "$matches" ]; then
        BLOCKED+=("$matches")
    fi
done
if [ ${#BLOCKED[@]} -gt 0 ]; then
    echo ""
    echo "ERROR: Commit blocked — private research strategy files are staged:"
    for f in "${BLOCKED[@]}"; do
        echo "  $f"
    done
    echo ""
    echo "These files contain unpublished research strategy and must not be committed."
    echo "Run: git restore --staged <file>  to unstage them."
    echo ""
    exit 1
fi

# Ruff lint (auto-fix, then verify clean)
python3 -m ruff check . --fix --quiet
python3 -m ruff format . --quiet

# Stage any auto-fixes ruff made so they're included in the commit
git add -u

# mypy (non-blocking warning — mypy errors shouldn't silently break a commit
# but also shouldn't prevent saving work; promote to exit 1 when ready)
if ! python -m mypy dash_shap --ignore-missing-imports --quiet 2>/dev/null; then
    echo "WARNING: mypy found type errors. Run 'make typecheck' to review."
    echo "  (commit allowed — fix before pushing)"
fi

echo "Pre-commit checks passed."
exit 0
