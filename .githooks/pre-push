#!/usr/bin/env bash
# Pre-push hook: block .pkl files and files >1MB from being pushed.
# Install: git config core.hooksPath .githooks

MAX_SIZE=1048576  # 1MB
ERRORS=0

while read local_ref local_sha remote_ref remote_sha; do
    # Determine commit range
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch — check all commits reachable from local_sha
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    files=$(git diff --name-only --diff-filter=ACM "$range" 2>/dev/null)

    for file in $files; do
        # Block .pkl files
        if [[ "$file" == *.pkl ]]; then
            echo "BLOCKED: $file is a .pkl file. Remove it from the commit."
            ERRORS=$((ERRORS + 1))
            continue
        fi

        # Block files over MAX_SIZE
        if git cat-file -e "$local_sha:$file" 2>/dev/null; then
            size=$(git cat-file -s "$local_sha:$file" 2>/dev/null || echo 0)
            if [ "$size" -gt "$MAX_SIZE" ] 2>/dev/null; then
                echo "BLOCKED: $file is $(( size / 1024 ))KB (limit: $(( MAX_SIZE / 1024 ))KB)"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
done

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "$ERRORS file(s) blocked. To override: git push --no-verify"
    exit 1
fi
exit 0
