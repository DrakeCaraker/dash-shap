#!/usr/bin/env bash
# Pre-push hook: enforces branch hygiene, local CI checks, and file safety.
# Install: git config core.hooksPath .githooks

# --- 1. Block direct pushes to main (always first) ---
current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "$current_branch" = "main" ]; then
    echo "BLOCKED: Direct push to main is not allowed."
    echo "  Create a feature branch: git checkout -b feat/<topic>"
    echo "  To override (emergency only): git push --no-verify"
    exit 1
fi

# --- 2. Ruff lint + format check (blocking) ---
RUFF_CMD=""
if command -v ruff >/dev/null 2>&1; then
    RUFF_CMD="ruff"
elif python3 -m ruff --version >/dev/null 2>&1; then
    RUFF_CMD="python3 -m ruff"
fi

if [ -n "$RUFF_CMD" ]; then
    if ! $RUFF_CMD check . --quiet 2>&1; then
        echo "BLOCKED: ruff lint errors found. Run 'make lint' to see details."
        exit 1
    fi
    if ! $RUFF_CMD format --check . --quiet 2>&1; then
        echo "BLOCKED: ruff format check failed. Run 'make fmt' to fix."
        exit 1
    fi
else
    echo "WARNING: ruff not found — skipping lint/format checks (install ruff to enforce locally)."
fi

# --- 3. Mypy type check (blocking) ---
MYPY_CMD=""
if command -v mypy >/dev/null 2>&1; then
    MYPY_CMD="mypy"
elif python3 -m mypy --version >/dev/null 2>&1; then
    MYPY_CMD="python3 -m mypy"
fi

if [ -n "$MYPY_CMD" ]; then
    if ! $MYPY_CMD dash_shap/ --ignore-missing-imports --no-error-summary --quiet 2>&1; then
        echo "BLOCKED: mypy type errors found. Run 'make typecheck' to see details."
        exit 1
    fi
else
    echo "WARNING: mypy not found — skipping type checks."
fi

# --- 4. Warn on result JSONs produced with dirty working tree (non-blocking) ---
python3 -c "
import json, glob
dirty = []
for f in sorted(glob.glob('results/tables/*.json')):
    try:
        d = json.loads(open(f).read())
        if d.get('_meta', {}).get('code_dirty'):
            dirty.append(f)
    except Exception:
        pass
if dirty:
    print('WARNING: results produced with uncommitted code (code_dirty=true):')
    for f in dirty:
        print(f'  {f}')
    print('  These results may not be fully reproducible from the committed codebase.')
" 2>/dev/null

# --- 5. Drift warning (non-blocking) ---
if [ "$current_branch" != "HEAD" ]; then
    git fetch origin main --quiet 2>/dev/null
    if git rev-parse origin/main >/dev/null 2>&1; then
        behind=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
        if [ "$behind" -gt 0 ]; then
            echo "WARNING: Branch '$current_branch' is $behind commit(s) behind origin/main."
            echo "  Consider rebasing: git rebase origin/main"
            echo ""
        fi
    fi
fi

# --- 6. File checks: block .pkl and files >10MB (blocking) ---
MAX_SIZE=10485760  # 10MB
ERRORS=0

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    files=$(git diff --name-only --diff-filter=ACM "$range" 2>/dev/null)

    for file in $files; do
        if [[ "$file" == *.pkl ]]; then
            echo "BLOCKED: $file is a .pkl file. Remove it from the commit."
            ERRORS=$((ERRORS + 1))
            continue
        fi

        if git cat-file -e "$local_sha:$file" 2>/dev/null; then
            size=$(git cat-file -s "$local_sha:$file" 2>/dev/null || echo 0)
            if [ "$size" -gt "$MAX_SIZE" ] 2>/dev/null; then
                echo "BLOCKED: $file is $(( size / 1024 ))KB (limit: $(( MAX_SIZE / 1024 ))KB)"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
done

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "$ERRORS file(s) blocked. To override: git push --no-verify"
    exit 1
fi
exit 0
