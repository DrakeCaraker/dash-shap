    "]\n",
    "\n",
    "print('Statistical Significance Tests (Wilcoxon signed-rank):')\n",
    "print(f'{\"\\u03c1\":>5} {\"Comparison\":<35} {\"Metric\":<12} {\"p-value\":>10} {\"Cohen d\":>10}')\n",
    "print('=' * 80)\n",
    "\n",
    "for rho, m1, m2 in comparisons:\n",
    "    if rho not in sweep_results:\n",
