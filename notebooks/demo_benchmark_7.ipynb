    "    criteria.append(('Safety at \\u03c1=0', f'gap={gap:.4f}', passed))\n",
    "    print(f'3. Safety at \\u03c1=0: gap={gap:.4f} \\u2192 {\"PASS\" if passed else \"FAIL\"}')\n",
