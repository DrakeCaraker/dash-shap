ions derive from this; overrides are documented inline.\nPAPER_CONFIG = {\n    'M': 200,        # Main sweep uses M=200; epsilon sensitivity also uses M=200\n    'K': 30,         # K_eff hits ceiling at K=10 with ε=0.08 — K=30 provides headroom\n    'N_REPS': 20,    # Repetitions for stability measurement\n    'EPSILON': 0.08,  # Sweet spot: K_eff=10.0±0.0, 114 models passing, flat performance above\n    'DELTA': 0.05,    # Unchanged — no sensitivity analysis run on this\n    'N_TRIALS_SB': 30,  # B2: SingleBestBaseline hyperparameter trials (consistent everywhere)\n    'T_PER_MODEL': 500,  # Trees per model in LargeSingleModel baseline\n    'N_ESTIMATORS_ESHAP': 2000,  # Trees for Ensemble SHAP baseline\n    'TAU_CLUSTER': 0.3,   # Cluster coverage: within-cluster distance threshold\n}\n\nSEED = 42\nM = PAPER_CONFIG['M']\nK = PAPER_CONFIG['K']\nN_REPS = PAPER_CONFIG['N_REPS']\nEPSILON = PAPER_CONFIG['EPSILON']\nDELTA = PAPER_CONFIG['DELTA']\nN_TRIALS_SB = PAPER_CONFIG['N_TRIALS_SB']\nfeature_names = [f'G{g}_f{j}' for g in range(10) for j in range(5)]\n\n# F2 fix: Scale-invariant epsilon for real-world datasets via relative mode\nREAL_EPSILON = 0.05\nREAL_EPSILON_MODE = 'relative'\n\nprint(f'\\nDASH loaded. Config: M={M}, K={K}, N_REPS={N_REPS}, ε={EPSILON}, δ={DELTA}')\nprint(f'  Real-data: ε={REAL_EPSILON} (mode={REAL_EPSILON_MODE})')\n_notebook_start = time.time()  # N13: wall-clock timing\n\n\n# ===== CHECKPOINTING INFRASTRUCTURE =====\nimport pickle, hashlib, os\n\nCHECKPOINT_DIR = os.path.join(os.path.dirname(os.path.abspath('.')), 'checkpoints')\nos.makedirs(CHECKPOINT_DIR, exist_ok=True)\n\ndef _ckpt_path(name):\n    \"\"\"Return the checkpoint file path for a given section name.\"\"\"\n    return os.path.join(CHECKPOINT_DIR, f'ckpt_{name}.pkl')\n\ndef save_checkpoint(name, **data):\n    \"\"\"Save intermediate results to disk.\"\"\"\n    path = _ckpt_path(name)\n    with open(path, 'wb') as f:\n        pickle.dump(data, f, protocol=pickle.HIGHEST_PROTOCOL)\n    size_mb = os.path.getsize(path) / (1024 * 1024)\n    print(f'  [CHECKPOINT] Saved {name} ({size_mb:.1f} MB)')\n\ndef load_checkpoint(name):\n    \"\"\"Load a checkpoint if it exists. Returns dict or None.\"\"\"\n    path = _ckpt_path(name)\n    if os.path.exists(path):\n        with open(path, 'rb') as f:\n            data = pickle.load(f)\n        size_mb = os.path.getsize(path) / (1024 * 1024)\n        print(f'  [CHECKPOINT] Loaded {name} ({size_mb:.1f} MB)')\n        return data\n    return None\n\ndef has_checkpoint(name):\n    \"\"\"Check if a checkpoint exists.\"\"\"\n    return os.path.exists(_ckpt_path(name))\n\ndef clear_checkpoint(name):\n    \"\"\"Remove a specific checkpoint.\"\"\"\n    path = _ckpt_path(name)\n    if os.path.exists(path):\n        os.remove(path)\n        print(f'  [CHECKPOINT] Cleared {name}')\n\ndef clear_all_checkpoints():\n    \"\"\"Remove all checkpoints. Use when you want a full clean re-run.\"\"\"\n    for fn in os.listdir(CHECKPOINT_DIR):\n        if fn.startswith('ckpt_') and fn.endswith('.pkl'):\n            os.remove(os.path.join(CHECKPOINT_DIR, fn))\n    print('  [CHECKPOINT] All checkpoints cleared.')\n\nprint(f'Checkpoint directory: {CHECKPOINT_DIR}')\nexisting = [fn for fn in os.listdir(CHECKPOINT_DIR) if fn.startswith('ckpt_')]\nif existing:\n    print(f'  Found {len(existing)} existing checkpoint(s): {\", \".join(sorted(existing))}')\nelse:\n    print('  No existing checkpoints found. Full run will execute.')",
