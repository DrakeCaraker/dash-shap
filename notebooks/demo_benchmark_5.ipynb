r m in ['Single Best', 'DASH (MaxMin)']:\n        stab = importance_stability(vd_results[cond][m])\n        vd_summary[cond][m] = stab\n        print(f'{cond:<16} {m:<20} {stab:>10.4f}')\n\nprint('\\nVariance Decomposition Ratios:')\nfor m in ['Single Best', 'DASH (MaxMin)']:\n    total_var = 1.0 - vd_summary['both_varied'][m]\n    model_var = 1.0 - vd_summary['data_fixed'][m]\n    data_var = 1.0 - vd_summary['model_fixed'][m]\n    if total_var > 0:\n        print(f'  {m}: model-selection={model_var/total_var:.1%}, '\n              f'data-sampling={data_var/total_var:.1%} of total instability')\n    else:\n        print(f'  {m}: total variance ≈ 0 (perfectly stable)')",
